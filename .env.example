# ─── Analytics ────────────────────────────────────────────
# PostHog project API key (get from posthog.com → Settings → Project API Key)
REACT_APP_POSTHOG=phc_your_key_here

# ─── Live Chat ─────────────────────────────────────────────
# Crisp website ID (get from crisp.chat → Settings → Website Settings)
REACT_APP_CRISP_ID=your_crisp_website_id_here

# ─── Database (server-side only, never expose in frontend) ─
# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings → API → anon public)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Frontend auth config for PCC
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 32-byte hex key for encrypting restricted data such as Plaid access tokens
PCC_ENCRYPTION_KEY=64_hex_characters_here

# PCC defaults
PCC_CLIENT_NAME=Personal Command Center
PCC_DEFAULT_TENANT=vallotaventures
PCC_APP_URL=https://vallotaventures.com
PCC_RATE_LIMIT_WINDOW_MS=60000
PCC_RATE_LIMIT_MAX=60

# Plaid
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_PRODUCTS=transactions,assets
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=https://vallotaventures.com/pcc/app
PLAID_WEBHOOK_URL=https://vallotaventures.com/api/pcc-plaid-webhook
